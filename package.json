{
  "name": "live-auction",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "npm run dev -w @live-auction/api & npm run dev -w @live-auction/web",
    "dev:api": "npm run dev -w @live-auction/api",
    "dev:web": "npm run dev -w @live-auction/web",
    "build": "npm run build -w @live-auction/shared && npm run build -w @live-auction/api && npm run build -w @live-auction/web",
    "test": "npm run test --workspaces --if-present",
    "lint": "eslint . --ext .ts,.tsx",
    "db:migrate": "npm run db:migrate -w @live-auction/api",
    "db:generate": "npm run db:generate -w @live-auction/api",
    "storage:reset": "node scripts/reset-storage.mjs"
  },
  "devDependencies": {
    "@eslint/js": "^9.17.0",
    "typescript-eslint": "^8.18.0",
    "eslint": "^9.17.0",
    "typescript": "^5.7.2"
  },
  "engines": {
    "node": ">=20"
  }
}
