# 生产 / 公网部署示例（复制为 .env 后修改）

NODE_ENV=production
PORT=3000

DATABASE_URL=mysql://auction:auction@mysql:3306/live_auction
REDIS_URL=redis://redis:6379

# 改为你的公网域名（含协议），多源逗号分隔
CORS_ORIGIN=https://your-domain.com

JWT_SECRET=replace-with-long-random-secret
JWT_EXPIRES_IN=7d

BID_RATE_LIMIT_PER_USER=2
BID_RATE_LIMIT_WINDOW_MS=1000
SOCKET_IO_REDIS_ADAPTER=true

# 前端构建（docker build 时传入，默认同源留空即可）
# VITE_API_URL=
# VITE_WS_URL=
VITE_USER_APP_URL=https://your-domain.com
VITE_ADMIN_APP_URL=https://your-domain.com/admin
VITE_ADMIN_BASE=/admin/
