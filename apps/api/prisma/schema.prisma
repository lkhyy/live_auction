generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  BUYER
  HOST
  ADMIN
}

enum LiveRoomStatus {
  PREPARE
  LIVE
  ENDED
}

enum AuctionStatus {
  DRAFT
  SCHEDULED
  LIVE
  CLOSING
  SETTLED
  CANCELLED
  FAILED
}

enum LotStatus {
  DRAFT
  ACTIVE
  SOLD
  ARCHIVED
}

enum AuctionEventType {
  STARTED
  BID_ACCEPTED
  SOFT_CLOSE_EXTENDED
  SETTLED
  CANCELLED
  CAP_REACHED
}

enum OrderStatus {
  PENDING_PAYMENT
  PAID
  CANCELLED
}

model User {
  id           String   @id @default(uuid())
  email        String   @unique
  passwordHash String   @map("password_hash")
  displayName  String   @map("display_name")
  role         UserRole @default(BUYER)
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  lots         Lot[]
  bids         Bid[]
  hostedAuctions Auction[] @relation("HostAuctions")
  wonAuctions  Auction[] @relation("WinnerAuctions")
  orders       Order[]
  liveRooms    LiveRoom[]

  @@map("users")
}

model Lot {
  id          String    @id @default(uuid())
  hostId      String    @map("host_id")
  title       String
  description String?   @db.Text
  imageUrl    String?   @map("image_url")
  category    String?
  status      LotStatus @default(DRAFT)
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")

  host     User      @relation(fields: [hostId], references: [id])
  auctions Auction[]

  @@index([hostId])
  @@map("lots")
}

model LiveRoom {
  id               String         @id @default(uuid())
  hostId           String         @map("host_id")
  title            String
  status           LiveRoomStatus @default(PREPARE)
  activeAuctionId  String?        @map("active_auction_id")
  startedAt        DateTime?      @map("started_at")
  endedAt          DateTime?      @map("ended_at")
  createdAt        DateTime       @default(now()) @map("created_at")
  updatedAt        DateTime       @updatedAt @map("updated_at")

  host     User      @relation(fields: [hostId], references: [id])
  auctions Auction[]

  @@index([hostId])
  @@index([status])
  @@map("live_rooms")
}

model Auction {
  id              String        @id @default(uuid())
  lotId           String        @map("lot_id")
  hostId          String        @map("host_id")
  roomId          String?       @map("room_id")
  sortOrder       Int           @default(0) @map("sort_order")
  title           String
  status          AuctionStatus @default(DRAFT)
  ruleSnapshot    Json          @map("rule_snapshot")
  scheduledStartAt DateTime?    @map("scheduled_start_at")
  startAt         DateTime?     @map("start_at")
  endAt           DateTime?     @map("end_at")
  capPrice        Decimal?      @map("cap_price") @db.Decimal(12, 2)
  currentPrice    Decimal       @default(0) @map("current_price") @db.Decimal(12, 2)
  winnerId        String?       @map("winner_id")
  settleReason    String?       @map("settle_reason")
  createdAt       DateTime      @default(now()) @map("created_at")
  updatedAt       DateTime      @updatedAt @map("updated_at")

  lot    Lot       @relation(fields: [lotId], references: [id])
  room   LiveRoom? @relation(fields: [roomId], references: [id])
  host   User      @relation("HostAuctions", fields: [hostId], references: [id])
  winner User?  @relation("WinnerAuctions", fields: [winnerId], references: [id])
  bids   Bid[]
  events AuctionEvent[]
  order  Order?

  @@index([status])
  @@index([lotId])
  @@index([roomId, sortOrder])
  @@map("auctions")
}

model Order {
  id        String      @id @default(uuid())
  auctionId String      @unique @map("auction_id")
  buyerId   String      @map("buyer_id")
  amount    Decimal     @db.Decimal(12, 2)
  status    OrderStatus @default(PENDING_PAYMENT)
  paidAt    DateTime?   @map("paid_at")
  createdAt DateTime    @default(now()) @map("created_at")
  updatedAt DateTime    @updatedAt @map("updated_at")

  auction Auction @relation(fields: [auctionId], references: [id])
  buyer   User    @relation(fields: [buyerId], references: [id])

  @@index([buyerId])
  @@index([status])
  @@map("orders")
}

model Bid {
  id             String   @id @default(uuid())
  auctionId      String   @map("auction_id")
  userId         String   @map("user_id")
  amount         Decimal  @db.Decimal(12, 2)
  idempotencyKey String?  @unique @map("idempotency_key")
  createdAt      DateTime @default(now()) @map("created_at")

  auction Auction @relation(fields: [auctionId], references: [id])
  user    User    @relation(fields: [userId], references: [id])

  @@index([auctionId, amount(sort: Desc)])
  @@index([userId])
  @@map("bids")
}

model AuctionEvent {
  id        String           @id @default(uuid())
  auctionId String           @map("auction_id")
  type      AuctionEventType
  payload   Json
  createdAt DateTime         @default(now()) @map("created_at")

  auction Auction @relation(fields: [auctionId], references: [id])

  @@index([auctionId])
  @@map("auction_events")
}
