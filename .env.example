# Database
DATABASE_URL=mysql://auction:auction@localhost:3306/live_auction

# Redis
REDIS_URL=redis://localhost:6379

# API
PORT=3000
NODE_ENV=development
CORS_ORIGIN=http://localhost:5173,http://localhost:5174

# JWT
JWT_SECRET=change-me-in-production-use-long-random-string
JWT_EXPIRES_IN=7d

# Rate limiting
BID_RATE_LIMIT_PER_USER=2
BID_RATE_LIMIT_WINDOW_MS=1000

# Socket.io
SOCKET_IO_REDIS_ADAPTER=true

# Frontend (Vite) — 用户端与管理端分端口部署
VITE_APP_TARGET=user
VITE_USER_APP_URL=http://localhost:5173
VITE_ADMIN_APP_URL=http://localhost:5174
VITE_API_URL=http://localhost:3000
VITE_WS_URL=http://localhost:3000

# 生产 / Docker 公网部署见 .env.production.example（VITE_API_URL 留空表示同源反代）
